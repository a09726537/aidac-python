def test_fetch_events_uses_read_only_connection(
    monkeypatch: pytest.MonkeyPatch,
) -> None:
    """The connector must request a read-only PostgreSQL session."""

    captured: dict[str, Any] = {}

    rows = [
        {
            "event_time": datetime.now(timezone.utc),
            "query_text": "SELECT 1;",
            "username": "health_user",
            "database_name": "postgres",
            "client_ip": None,
            "duration_ms": 1.0,
            "rows_affected": 1,
        }
    ]

    def fake_connect(
        *args: object,
        **kwargs: object,
    ) -> FakeConnection:
        captured["args"] = args
        captured["kwargs"] = kwargs
        return FakeConnection(rows)

    monkeypatch.setattr(
        postgresql_module.psycopg,
        "connect",
        fake_connect,
    )

    connector = PostgreSQLAuditConnector(
        PostgreSQLAuditConfig(
            dsn="postgresql://readonly@localhost/postgres"
        )
    )

    events = connector.fetch_events(limit=10)

    assert len(events) == 1
    assert events[0].query == "SELECT 1;"

    options = str(captured["kwargs"]["options"])
    assert "default_transaction_read_only=on" in options
    assert captured["kwargs"]["autocommit"] is True
    assert captured["kwargs"]["application_name"] == "aidac-python"
PYL session."""

    captured: dict[str, Any] = {}

    rows = [
        {
            "event_time": datetime.now(timezone.utc),
            "query_text": "SELECT 1;",
            "username": "health_user",
            "database_name": "postgres",
            "client_ip": None,
            "duration_ms": 1.0,
            "rows_affected": 1,
        }
    ]

    def fake_connect(
        *args: object,
        **kwargs: object,
    ) -> FakeConnection:
        captured["args"] = args
        captured["kwargs"] = kwargs
        return FakeConnection(rows)

    monkeypatch.setattr(
        postgresql_module.psycopg,
        "connect",
        fake_connect,
    )

    connector = PostgreSQLAuditConnector(
        PostgreSQLAuditConfig(
            dsn="postgresql://readonly@localhost/postgres"
        )
    )

    events = connector.fetch_events(limit=10)

    assert len(events) == 1
    assert events[0].query == "SELECT 1;"

    options = str(captured["kwargs"]["options"])
    assert "default_transaction_read_only=on" in options
    assert captured["kwargs"]["autocommit"] is True
    assert captured["kwargs"]["application_name"] == "aidac-python"
